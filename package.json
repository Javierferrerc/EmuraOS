{
  "name": "retro-launcher",
  "version": "0.2.0",
  "description": "Open-source retro gaming frontend — detect ROMs, map emulators, launch games",
  "type": "module",
  "main": ".vite/build/index.js",
  "exports": {
    ".": "./dist/core/index.js"
  },
  "bin": {
    "retro-launcher": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "scan": "node dist/cli/index.js scan",
    "start": "node dist/cli/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:electron": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "keywords": [
    "retro",
    "gaming",
    "emulator",
    "launcher",
    "roms",
    "electron"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "enquirer": "^2.4.1",
    "glob": "^11.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
