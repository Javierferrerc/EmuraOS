{
  "name": "retro-launcher",
  "version": "0.1.0",
  "description": "Open-source retro gaming frontend — detect ROMs, map emulators, launch games",
  "type": "module",
  "main": "dist/core/index.js",
  "bin": {
    "retro-launcher": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "scan": "node dist/cli/index.js scan",
    "start": "node dist/cli/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["retro", "gaming", "emulator", "launcher", "roms"],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "glob": "^11.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
