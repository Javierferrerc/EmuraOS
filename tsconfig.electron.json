{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist-electron",
    "sourceMap": true
  },
  "include": [
    "src/electron/main/**/*.ts",
    "src/electron/preload/**/*.ts",
    "src/core/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
